@using Pinula.Shared.DTOs
@using Pinula.Shared.Interface
@inject IRecipeService RecipeService
@inject NavigationManager Navigation

<h3>Manage Recipes</h3>

@if (recipes == null)
{
    <div class="spinner-border text-primary" role="status"></div>
}
else if (!recipes.Any())
{
    <div class="alert alert-info">No recipes found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Admin approval</th>
                <th>Deleted</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var recipe in recipes)
            {
                <tr>
                    <td><strong>@recipe.Title</strong></td>
                    <td>
                        @if (recipe.IsApproved)
                        {
                            <span class="badge bg-success">Approved</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Hidden / Banned</span>
                        }
                    </td>
                    <td>
                        @if (!recipe.IsDeleted)
                        {
                            <span class="badge bg-success">Visible</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Deleted</span>
                        }
                    </td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick='() => Navigation.NavigateTo($"/recipe/{recipe.Id}")'>View Details
                        </button>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick='() => SwitchApproval(recipe)'>Switch Approval
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<RecipePreviewDto>? recipes;

    protected override async Task OnInitializedAsync()
    {
        var adminParams = new RecipeFilterParameters
        {
            Sort = SortBy.Newest,
            SortDescending = true,
            IncludeUnapproved = true,
            Amount = 100
        };

        recipes = await RecipeService.GetFilteredRecipePreviewsAsync(adminParams, null);
    }

    private async Task SwitchApproval(RecipePreviewDto dto)
    {
        dto.IsApproved = !dto.IsApproved;

        await RecipeService.AdminToggleRecipeApprovalAsync(dto.Id);
    }
}
