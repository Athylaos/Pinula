@using Pinula.Shared.Models
@using Pinula.Shared.DTOs
@using Pinula.Shared.Interface
@inject IUnitService UnitService

<h3>Manage Units</h3>

<div class="mb-4" style="max-width: 400px;">
    <input type="text" class="form-control" placeholder="New unit code" @bind="newUnitCode" />
    <input type="text" class="form-control" placeholder="New unit name english" @bind="newUnitNameEn" />
    <input type="text" class="form-control" placeholder="New unit name czech" @bind="newUnitNameCs" />
    <div class="flex-row align-items-center">
        <p class="d-inline">Is serving unit?</p>
        <input type="checkbox" class="form-check" @bind="newUnitServing" />
    </div>
    <button class="btn-close-white" @onclick="HandleCreate">Add Unit</button>
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert alert-warning py-2">@statusMessage</div>
}

@if (units == null)
{
    <div class="spinner-border text-primary" role="status"></div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Code</th>
                <th>Name EN</th>
                <th>Name CS</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var unit in units)
            {
                <tr>
                    <td class="small text-muted">@unit.Id</td>
                    <td><strong>@unit.Code</strong></td>
                    <td>@unit.Names["en"]</td>
                    <td>@unit.Names["cs"]</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => HandleDelete(unit.Id)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Unit>? units;
    private string newUnitNameEn = "";
    private string newUnitNameCs = "";
    private string newUnitCode = "";
    private bool newUnitServing;
    private string statusMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUnits();
    }

    private async Task LoadUnits()
    {
        var result = await UnitService.GetAllUnitsAdminAsync();
        units = result.ToList();
    }

    private async Task HandleCreate()
    {
        if (string.IsNullOrWhiteSpace(newUnitNameCs) || string.IsNullOrWhiteSpace(newUnitNameEn) || string.IsNullOrWhiteSpace(newUnitCode)) return;

        var success = await UnitService.CreateUnitAsync(new Unit { Names = new Dictionary<string, string>{{"en", newUnitNameEn}, {"cs", newUnitNameCs}}, IsServingUnit = newUnitServing, Code = newUnitCode });
        if (success)
        {
            newUnitCode = "";
            newUnitNameCs = "";
            newUnitNameEn = "";
            newUnitServing = false;
            statusMessage = "";
            await LoadUnits();
        }
        else
        {
            statusMessage = "Failed to create unit.";
        }
    }

    private async Task HandleDelete(Guid id)
    {
        var success = await UnitService.DeleteUnitAsync(id);
        if (success)
        {
            statusMessage = "";
            await LoadUnits();
        }
        else
        {
            statusMessage = "Cannot delete unit (it might be in use).";
        }
    }
}