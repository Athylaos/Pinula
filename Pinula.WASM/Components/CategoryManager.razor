@using Pinula.Shared.Models
@using Pinula.Shared.DTOs
@using Pinula.Shared.Interface
@inject ICategoryService CategoryService

<h3>Manage Categories</h3>

<div class="card p-3 mb-4 shadow-sm" style="max-width: 500px; background-color: #f8f9fa;">
    <h5 class="card-title">Create New Category</h5>
    
    <div class="row g-2">
        <div class="col-12">
            <input type="text" class="form-control" placeholder="Category Name English" @bind="newCategoryNameEn" />
            <input type="text" class="form-control" placeholder="Category Name Czech" @bind="newCategoryNameCs" />
        </div>

        <div class="col-8">
            <select class="form-control" @bind="selectedParentId">
                <option value="">-- No Parent (Main) --</option>
                @if (displayCategories != null)
                {
                    @foreach (var cat in displayCategories)
                    {
                        <option value="@cat.Id">
                            @(new string('—', cat.Level * 2)) @cat.Names.GetValueOrDefault("en")
                        </option>
                    }
                }
            </select>
        </div>

        <div class="col-4">
            <input type="number" class="form-control" placeholder="Order" @bind="newSortOrder" />
        </div>

        <div class="col-12">
            <div class="custom-file-upload">
                <label for="category-image-upload" class="btn btn-outline-secondary btn-sm w-100">
                    <i class="bi bi-image"></i> @(string.IsNullOrEmpty(selectedFileName) ? "Select Image" : selectedFileName)
                </label>
                <InputFile id="category-image-upload" OnChange="LoadPhoto" style="display: none;" accept="image/*" />
            </div>
        </div>

        <div class="col-12 mt-2">
            <button class="btn btn-success w-100" @onclick="HandleCreate">Create Category</button>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert alert-warning py-2">@statusMessage</div>
}

@if (displayCategories == null)
{
    <div class="spinner-border text-primary" role="status"></div>
}
else
{
    <p class="text-muted small">Total categories: @displayCategories.Count</p>
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th style="width: 60px;">Order</th>
                <th style="width: 80px;">Image</th>
                <th>Name EN</th>
                <th>Name CS</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in displayCategories)
            {
                <tr class="@(category.Level == 0 ? "fw-bold" : category.Level == 1 ? "table-light" : "")">
                    <td class="text-center text-muted">@category.SortOrder</td>
                    <td>
                        @if (!string.IsNullOrEmpty(category.PictureUrl) && category.PictureUrl != "default_category_picture.png")
                        {
                            <img src="@category.PictureUrl"
                                 style="width: 35px; height: 35px; object-fit: cover; border-radius: 5px;" />
                        }
                    </td>
                    <td>
                        <div style="padding-left: @(category.Level * 30)px">
                            @if (category.Level > 0)
                            {
                                <span class="text-muted me-1">↳</span>
                            }
                            @category.Names.GetValueOrDefault("en")
                        </div>
                    </td>
                    <td>

                        @category.Names.GetValueOrDefault("cs")
                    </td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => HandleDelete(category.Id)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<AdminCategoryDisplayDto>? displayCategories;

    private string newCategoryNameEn = "";
    private string newCategoryNameCs = "";
    private Guid? selectedParentId;
    private short newSortOrder = 0;
    private string statusMessage = "";
    private IBrowserFile? selectedFile;
    private string selectedFileName = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        displayCategories = await CategoryService.GetAllCategoriesAdminAsync();
        StateHasChanged();
    }

    private void LoadPhoto(InputFileChangeEventArgs e) { selectedFile = e.File; selectedFileName = e.File.Name; }

    private async Task HandleCreate()
    {
        if (string.IsNullOrWhiteSpace(newCategoryNameEn)) return;
        if (string.IsNullOrWhiteSpace(newCategoryNameCs)) return;

        var newNames = new Dictionary<string, string> { { "en", newCategoryNameEn }, { "cs", newCategoryNameCs } };

        var dto = new CategoryCreateDto { Names = newNames, ParentCategory = selectedParentId, SortOrder = newSortOrder };
        Stream? stream = null;
        if (selectedFile != null) stream = selectedFile.OpenReadStream(5 * 1024 * 1024);
        var resultId = await CategoryService.SaveCategoryAsync(dto, stream, selectedFile?.Name, selectedFile?.ContentType);
        if (resultId != null) { newCategoryNameEn = ""; newCategoryNameCs = ""; selectedParentId = null; newSortOrder = 0; selectedFile = null; selectedFileName = ""; await LoadCategories(); }
        else { statusMessage = "Failed to create category."; }
    }

    private async Task HandleDelete(Guid id)
    {
        if (await CategoryService.DeleteCategoryAsync(id)) await LoadCategories();
        else statusMessage = "Cannot delete: Category has children or is used.";
    }
}