@using Pinula.Shared.DTOs
@using System.Globalization
@using Pinula.Shared.Interface
@inject ILocalStorage LocalStorage

<div class="weekly-navigation-container">
    <button class="nav-arrow-btn" @onclick="() => HandleWeekChange(false)">
        <i class="bi bi-chevron-left"></i>
    </button>

    <div class="weekly-strip">
        @foreach (var date in _displayedDates)
        {
            var isSelected = date.Date == SelectedDate.Date;
            var isToday = date.Date == DateTime.Today;
            var hasMeals = WeeklyPlans.Any(p => p.Date == DateOnly.FromDateTime(date.Date));

            <div class="day-bubble @(isSelected ? "selected" : "") @(isToday ? "today" : "")"
                 @onclick="() => OnDateSelected.InvokeAsync(date)">

                <span class="day-name">@date.ToString("ddd", Culture)</span>
                <span class="day-number">@date.Day</span>

                <div class="indicator-area">
                    @if (hasMeals)
                    {
                        <div class="meal-dot"></div>
                    }
                </div>
            </div>
        }
    </div>

    <button class="nav-arrow-btn" @onclick="() => HandleWeekChange(true)">
        <i class="bi bi-chevron-right"></i>
    </button>
</div>

@code {
    [Parameter] public DateTime CurrentWeekStart { get; set; }
    [Parameter] public DateTime SelectedDate { get; set; }
    [Parameter] public List<MealPlanPreviewDto> WeeklyPlans { get; set; } = new();
    [Parameter] public EventCallback<DateTime> OnDateSelected { get; set; }
    [Parameter] public EventCallback<bool> OnWeekChangedForward { get; set; }
    [Parameter] public CultureInfo Culture { get; set; }

    private List<DateTime> _displayedDates = new();




    protected override void OnParametersSet()
    {
        GenerateWeeklyDays();
    }

    private void GenerateWeeklyDays()
    {
        _displayedDates.Clear();
        for (int i = 0; i < 7; i++)
        {
            _displayedDates.Add(CurrentWeekStart.AddDays(i));
        }
    }

    private async Task HandleWeekChange(bool direction)
    {
        await OnWeekChangedForward.InvokeAsync(direction);

    }
}