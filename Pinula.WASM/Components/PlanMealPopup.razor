@using Pinula.Shared.DTOs
@using Pinula.Shared.Enums
@using Pinula.Shared.Interface
@inject IRecipeService RecipeService

<div class="modal-overlay" @onclick="Cancel">
    <div class="glass-modal plan-meal-modal" @onclick:stopPropagation>
        <div class="modal-header">
            <img src="images/icons/calendar.png" style="filter: invert(1); width:30px; height:30px; margin-right:10px;" />
            <h2 style ="display:inline-block"> Add to Plan</h2>
            <button class="close-modal-btn" @onclick="Cancel">&times;</button>
        </div>

        <div class="modal-body">
            <div class="form-row-2">
                <div class="modal-section">
                    <label class="section-label">Date</label>
                    <input type="date" @bind="PlanDate" class="modal-input" />
                </div>
                <div class="modal-section">
                    <label class="section-label">Meal</label>
                    <select @bind="SelectedMealType" class="modal-input">
                        @foreach (var type in Enum.GetValues<MealType>())
                        {
                            <option value="@type">@type.ToString()</option>
                        }
                    </select>
                </div>
            </div>

            <div class="modal-section">
                <label class="section-label">Recipe</label>
                @if (PreselectedRecipeId.HasValue)
                {
                    <div class="preselected-recipe-card">
                        <div class="recipe-info">
                            <span>Recipe is selected from detail page.</span>
                        </div>
                    </div>
                }
                else
                {
                    <select @bind="SelectedRecipeId" class="modal-input">
                        <option value="">-- Select your favorite recipe --</option>
                        @foreach (var recipe in FvRecipes)
                        {
                            <option value="@recipe.Id">@recipe.Title</option>
                        }
                    </select>
                }
            </div>

            <div class="modal-section">
                <div class="section-header-flex">
                    <label class="section-label">Who is eating?</label>
                    <div class="servings-selector">
                        <label>Servings:</label>
                        <input type="number" min="1" @bind="Servings" class="input-servings" />
                    </div>
                </div>

                <div class="eaters-selection">
                    @foreach (var member in GroupMembers)
                    {
                        var isSelected = SelectedUsers.Contains(member.Id);
                        <div class="eater-avatar-wrapper @(isSelected ? "selected" : "")" @onclick="() => ToggleUser(member.Id)">
                            <img src="@member.AvatarUrl" alt="@member.Name" class="eater-avatar" />
                            @if (isSelected)
                            {
                                <div class="eater-check"><i class="fas fa-check"></i></div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-cancel-mp" @onclick="Cancel">Cancel</button>
                <button class="btn-accent" disabled="@(!IsValid)" @onclick="ConfirmSave">
                    Save Plan
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public DateOnly? PreselectedDate { get; set; }
    [Parameter] public MealType? PreselectedMealType { get; set; }
    [Parameter] public Guid? PreselectedRecipeId { get; set; }
    [Parameter] public List<UserDisplayDto> GroupMembers { get; set; } = new();
    [Parameter] public GroupDetailDto GroupDetail { get; set; }
    [Parameter] public List<RecipePreviewDto> FvRecipes { get; set; } = new();
    [Parameter] public EventCallback<CreateMealPlanDto> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private DateOnly PlanDate = DateOnly.FromDateTime(DateTime.Today);
    private MealType SelectedMealType = MealType.Lunch;
    private Guid? SelectedRecipeId;
    private int Servings = 1;
    private HashSet<Guid> SelectedUsers = new();



    protected override void OnInitialized()
    {
        if (PreselectedDate.HasValue) PlanDate = PreselectedDate.Value;
        if (PreselectedMealType.HasValue) SelectedMealType = PreselectedMealType.Value;
        if (PreselectedRecipeId.HasValue) SelectedRecipeId = PreselectedRecipeId.Value;

        foreach (var member in GroupMembers)
        {
            SelectedUsers.Add(member.Id);
        }
        Servings = SelectedUsers.Count > 0 ? SelectedUsers.Count : 1;
    }

    private async Task LoadData()
    {
        FvRecipes = await RecipeService.GetFilteredRecipePreviewsAsync(new RecipeFilterParameters { OnlyFavorites = true, Amount = 50 }, null);
    }

    private void ToggleUser(Guid userId)
    {
        if (SelectedUsers.Contains(userId))
            SelectedUsers.Remove(userId);
        else
            SelectedUsers.Add(userId);

        Servings = SelectedUsers.Count > 0 ? SelectedUsers.Count : 1;
    }

    private bool IsValid => SelectedRecipeId.HasValue && SelectedUsers.Any() && Servings > 0;

    private async Task ConfirmSave()
    {
        if (!IsValid) return;

        var dto = new CreateMealPlanDto
        {
            GroupId = GroupDetail.Id,
            Date = PlanDate,
            MealType = SelectedMealType,
            RecipeId = SelectedRecipeId.Value,
            Servings = Servings,
            UsersId = SelectedUsers.ToList()
        };

        await OnSave.InvokeAsync(dto);
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();
}