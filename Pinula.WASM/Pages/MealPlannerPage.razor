@page "/planner"
@using Pinula.Shared.DTOs
@using Pinula.Shared.Interface
@using Pinula.Shared.Enums
@using Pinula.WASM.Components
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IMealPlanService MealPlanService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager
@inject IRecipeService RecipeService
@inject IUserService UserService
@inject IStringLocalizer<App> Localizer
@inject ILocalStorage LocalStorage

<PageTitle>Pinula - @Localizer["PlannerPage"]</PageTitle>

<div class="planner-container">
    <header class="planner-header-panel">
        <div class="header-brand">
            <div class="header-icon-box">
                <img src="images/icons/calendar.png" class="header-icon-box p-2" />
            </div>
            <div>
                @if (!isNotInGroup)
                {
                    <h1 class="page-title">@groupDetail?.Name</h1>
                    <p class="subtitle">@Localizer["KitchenDashboard"]</p>
                }
                else
                {
                    <h1 class="page-title">@Localizer["StartPlanning"]</h1>
                    <p class="subtitle">@Localizer["StartPlanningSubtitle"]</p>
                }
            </div>
        </div>

        <div class="mp-header-actions">
            @if (!isNotInGroup && Members != null && Members.Any())
            {
                <div class="avatar-row">
                    @foreach (var member in Members)
                    {
                        <div class="avatar-wrapper" title="@($"{member.Name} {member.Surname}")">
                            <img src="@member.AvatarUrl" alt="@member.Name" class="user-avatar" />
                            <span class="avatar-status-dot"></span>
                        </div>
                    }
                </div>
            }

            <button class="btn-group-action" @onclick="() => showGroupModal = true">
                <i class="@(isNotInGroup ? "" : "bi bi-gear")"></i>
                <span>@(isNotInGroup ? Localizer["SetupGroup"] : "")</span>
            </button>
        </div>
    </header>

    <LoadingView IsFullScreen="true" IsLoading="IsLoading" Text="@Localizer["LoadingPlans"]">
        @if (!isNotInGroup)
        {
            <WeeklyStrip CurrentWeekStart="SelectedWeekStartDate"
                         SelectedDate="SelectedDate"
                         WeeklyPlans="WeeklyPlans"
                         OnDateSelected="ChangeSelectedDate"
                         OnWeekChangedForward="ChangeWeekForward" 
                         Culture="_culture"/>

            <div class="day-view-container">
                <MealPlanDayView SelectedDate="SelectedDate"
                                 DayPlans="GetPlansForSelectedDate()"
                                 OnAddMeal="OpenAddMealModal"
                                 OnEditMeal="OpenEditPopup"
                                 OnMealSelected="MealClicked"/>
            </div>
        }
        else
        {
            <div class="no-group-showcase">
                <div class="showcase-art">
                    <div class="glow-sphere"></div>
                </div>
                <h2>@Localizer["NotInGroup"]</h2>
                <p>@Localizer["NotInGroupSubtitle"]</p>

                <div class="showcase-actions">
                    <div class="action-card">
                        <h3>@Localizer["CreateGroup"]</h3>
                        <p>@Localizer["CreateGroupSubtitle"]</p>
                        <div class="input-group-custom">
                            <input type="text" placeholder="@Localizer["CreateGroupPlaceholder"]" @bind="newGroupName" />
                            <button class="btn-accent" @onclick="CreateGroupFromShowcase">@Localizer["Create"]</button>
                        </div>
                    </div>

                    <div class="action-card">
                        <h3>@Localizer["JoinGroup"]</h3>
                        <p>@Localizer["JoinGroupSubtitle"]</p>
                        <div class="input-group-custom">
                            <input type="text" placeholder="XXXX-XXXX-XXXX" @bind="joinGroupCode" />
                            <button class="btn-accent-secondary" @onclick="JoinGroupFromShowcase">@Localizer["Join"]</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </LoadingView>
</div>

@if (showGroupModal)
{
    <GroupManagementPopup groupDetail="groupDetail"
                          isNotInGroup="isNotInGroup"
                          Members="Members"
                          OnClose="CloseGroupModal"
                          OnCreateGroup="HandleCreateGroup"
                          OnJoinGroup="HandleJoinGroup"
                          OnLeaveGroup="HandleLeaveGroup"
                          OnUpdateGroupName="HandleUpdateGroupName" />
}

@if (showPlanMealModal)
{
    <PlanMealPopup GroupMembers="Members"
                   GroupDetail="groupDetail"
                   FvRecipes="fvRecipes"
                   PreselectedDate="popupDate"
                   PreselectedMealType="popupMealType"
                   PreselectedRecipeId="popupRecipeId"
                   OnSave="HandleSaveMealPlan"
                   OnCancel="() => showPlanMealModal = false" />
}

<EditMealPopup @ref="editMealPopup" 
                   AllGroupMembers="Members" 
                   OnSave="SaveUpdatedPlanToDb" 
                   OnDelete="DeletePlanFromDb" />

@code {
    private bool IsLoading = true;
    private DateTime WeekStartDate;
    private DateTime SelectedWeekStartDate;
    private DateTime SelectedDate;

    private DateTime _loadedFromDate;
    private DateTime _loadedToDate;

    private List<MealPlanPreviewDto> WeeklyPlans = new();
    private List<UserDisplayDto> Members = new();
    private GroupDetailDto? groupDetail = new() { Name = "Not in group", InviteCode = "ERROR" };
    private List<RecipePreviewDto> fvRecipes = new();

    private bool isNotInGroup = false;
    private bool showGroupModal = false;

    private CultureInfo _culture;

    private string newGroupName = "";
    private string joinGroupCode = "";

    protected override async Task OnInitializedAsync()
    {

        SelectedDate = DateTime.Today;
        WeekStartDate = SelectedDate.AddDays(-(int)SelectedDate.DayOfWeek + (int)DayOfWeek.Monday);
        SelectedWeekStartDate = WeekStartDate;
        if (SelectedDate.DayOfWeek == DayOfWeek.Sunday) WeekStartDate = WeekStartDate.AddDays(-7);

        await SetCulture();
        await LoadData();


        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("preselectedRecipeId", out var recipeIdString))
        {
            if (Guid.TryParse(recipeIdString, out Guid recipeId))
            {
                popupRecipeId = recipeId;
                popupDate = DateOnly.FromDateTime(DateTime.Today);
                popupMealType = MealType.Lunch;
                showPlanMealModal = true;
            }
        }
    }

    private async Task LoadData()
    {
        IsLoading = true;
        if(!await UserService.IsUserLoggedInAsync()) NavManager.NavigateTo("/login");
        groupDetail = await MealPlanService.GetMyGroupAsync();
        if (groupDetail is null)
        {
            isNotInGroup = true;
            IsLoading = false;
            return;
        }
        isNotInGroup = false;

        DateTime from = WeekStartDate < SelectedWeekStartDate ? WeekStartDate : SelectedWeekStartDate;
        DateTime toMax = WeekStartDate > SelectedWeekStartDate ? WeekStartDate : SelectedWeekStartDate;
        DateTime to = toMax.AddDays(6);

        _loadedFromDate = from;
        _loadedToDate = to;

        WeeklyPlans = await MealPlanService.GetMyGroupMealPlansAsync(from, to) ?? new();
        Members = await MealPlanService.GetMembersAsync();
        fvRecipes = await RecipeService.GetFilteredRecipePreviewsAsync(new RecipeFilterParameters { OnlyFavorites = true, Amount = 50 }, null);
        IsLoading = false;
    }

    private async Task SetCulture()
    {
        var culture = await LocalStorage.GetStringAsync("culture");
        if (string.IsNullOrWhiteSpace(culture))
        {
            _culture = CultureInfo.GetCultureInfo("en-US");
        }
        else
        {
            _culture = CultureInfo.GetCultureInfo(culture);
        }

    }

    private void ChangeSelectedDate(DateTime date)
    {
        SelectedDate = date;
    }

    private async Task ChangeWeekForward(bool direction) // true forward, false backwards
    {
        if (direction)
        {
            SelectedWeekStartDate = SelectedWeekStartDate.AddDays(7);
        }
        else
        {
            SelectedWeekStartDate = SelectedWeekStartDate.AddDays(-7);
        }

        SelectedDate = SelectedWeekStartDate;
        DateTime targetWeekEnd = SelectedWeekStartDate.AddDays(6);

        if (direction && SelectedWeekStartDate > _loadedToDate)
        {
            var wp = await MealPlanService.GetMyGroupMealPlansAsync(SelectedWeekStartDate, targetWeekEnd) ?? new();
            WeeklyPlans.AddRange(wp);
            _loadedToDate = targetWeekEnd;
        }
        else if (!direction && targetWeekEnd < _loadedFromDate)
        {
            var wp = await MealPlanService.GetMyGroupMealPlansAsync(SelectedWeekStartDate, targetWeekEnd) ?? new();
            WeeklyPlans.AddRange(wp);
            _loadedFromDate = SelectedWeekStartDate;
        }

        StateHasChanged();
    }

    private IEnumerable<MealPlanPreviewDto> GetPlansForSelectedDate()
    {
        return WeeklyPlans.Where(p => p.Date == DateOnly.FromDateTime(SelectedDate));
    }




    private void CloseGroupModal()
    {
        showGroupModal = false;
    }

    private async Task HandleCreateGroup(string name)
    {
        IsLoading = true;
        var result = await MealPlanService.CreateGroupAsync(new CreateGroupDto { Name = name });
        if (result != null)
        {
            showGroupModal = false;
            await LoadData();
        }
        IsLoading = false;
    }

    private async Task HandleJoinGroup(string code)
    {
        IsLoading = true;
        var success = await MealPlanService.JoinGroupAsync(code);
        if (success)
        {
            showGroupModal = false;
            await LoadData();
        }
        IsLoading = false;
    }

    private async Task HandleLeaveGroup()
    {
        IsLoading = true;
        var success = await MealPlanService.LeaveGroupAsync();
        if (success)
        {
            showGroupModal = false;
            await LoadData();
        }
        IsLoading = false;
    }

    private async Task HandleUpdateGroupName(string newName)
    {
        await MealPlanService.RenameGroupAsync(newName);
        await LoadData();
        showGroupModal = false;
        StateHasChanged();
    }



    private async Task CreateGroupFromShowcase()
    {
        await HandleCreateGroup(newGroupName);
    }

    private async Task JoinGroupFromShowcase()
    {
        await HandleJoinGroup(joinGroupCode);
    }

    private async Task LeaveCurrentGroup()
    {
        await HandleLeaveGroup();
    }

    //POPUP edit

    private EditMealPopup editMealPopup;

    private void OpenEditPopup(Guid mealPlanId)
    {
        var selectedMeal = WeeklyPlans.FirstOrDefault(m => m.Id == mealPlanId);

        if (selectedMeal != null)
        {
            editMealPopup.Open(selectedMeal);
        }
    }

    private async Task SaveUpdatedPlanToDb(UpdateMealPlanDto updatedDto)
    {
        var suc = await MealPlanService.UpdateMealPlanAsync(updatedDto);

        if (suc)
        {
            await LoadData();
        }
    }

    private async Task DeletePlanFromDb(Guid id)
    {
        var suc = await MealPlanService.RemoveRecipeFromPlanAsync(id);

        if (suc)
        {
            await LoadData();
        }
    }



    //POPUP create 

    private bool showPlanMealModal = false;
    private DateOnly? popupDate;
    private MealType? popupMealType;
    private Guid? popupRecipeId;


    private void OpenAddMealModal(MealType type)
    {
        popupDate = DateOnly.FromDateTime(SelectedDate);
        popupMealType = type;
        popupRecipeId = null;
        showPlanMealModal = true;
    }

    private async Task HandleSaveMealPlan(CreateMealPlanDto newPlan)
    {
        IsLoading = true;
        showPlanMealModal = false;

        await MealPlanService.AddRecipeToPlanAsync(newPlan);
        await LoadData();
    }

    private void MealClicked(MealPlanPreviewDto mp) => NavManager.NavigateTo($"/recipe/{mp.RecipeId}");
}