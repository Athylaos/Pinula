@page "/recipes/add"
@page "/recipe/edit/{RecipeId:guid}"

@using Pinula.Shared.Models
@using Pinula.Shared.Enums
@using Pinula.Shared.DTOs
@using Pinula.Shared.Interface
@using Pinula.WASM.Components
@inject IUserService UserService
@inject IRecipeService RecipeService
@inject ICategoryService CategoryService
@inject IUnitService UnitService
@inject IIngredientService IngredientService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager

<LoadingView IsFullScreen="true" Text="Loading data..." IsLoading="isLoading">
    <div class="header">
        <img src="images/icons/back.png" class="back-btn" @onclick="GoBack" />
        <h1>@(IsEditMode ? "Edit Recipe" : "Add Recipe")</h1>
    </div>

    @if (userDto is null)
    {
        <p>You need to login</p> @*Is handled by automatic redirection*@
    }
    else if (!userDto.CanCreateRecipes)
    {
        <div class="comment-input-card">
            <div class="prompt-content">
                <h5>You have been banned</h5>
                <p>Your right to post recipes has been revoked by the administrator. You can appeal this decision through our support team.</p>
            </div>
        </div>
    }
    else
    {
        <div class="form-grid">
            <div class="add-recipe-card basic-info">
                <div class="input-group">
                    <label>Recipe name</label>
                    <input type="text" class="custom-input " @bind="Title" placeholder="e.g. Spaghetti Bolognese" />
                </div>
                <div class="w-100 mb-2" style="display: flex; justify-content: center; align-items: center;">
                    <div class="image-upload" style="display: flex; justify-content: center; align-items: center; width: 100%;">
                        <div class="image-preview" style="display: flex; flex-direction: column; justify-content: center; align-items: center; margin: 0 auto;">
                            @if (!string.IsNullOrEmpty(SelectedImagePreview))
                            {
                                <img src="@SelectedImagePreview" alt="Recipe preview" style="max-width: 100%; max-height: 200px; object-fit: contain; display: block; margin: 0 auto;" />
                            }
                            else
                            {
                                <span style="text-align: center; display: block; width: 100%;">No image selected</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="custom-file-upload">
                    <label for="file-upload" class="btn-apply">
                        Select image
                    </label>
                    <InputFile id="file-upload" OnChange="LoadPhoto" />
                </div>

                <div class="stats-row">
                    <div class="input-group">
                        <label>Time (Minutes)</label>
                        <input type="number" min="1" class="custom-input" @bind="Time" />

                    </div>

                    <div class="input-group">
                        <label>Servings</label>
                        <div class="flex-row">
                            <input type="number" min="1" class="custom-input" @bind="Servings" />
                            <select class="custom-select" @bind="SelectedServingUnitId">
                                @foreach (var unit in ServingUnits)
                                {
                                    <option value="@unit.Id">@unit.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>Difficulty</label>
                        <select class="custom-select" @bind="Difficulty">
                            @foreach (var diff in DifficultyOptions)
                            {
                                <option value="@diff">@diff.ToString()</option>
                            }
                        </select>
                    </div>
                </div>
            </div>


            <div class="add-recipe-card">
                <label class="section-title">Categories</label>

                <div class="category-root-container">
                    @foreach (var root in Categories.Where(c => c.Category.ParentCategoryId == null || c.Category.ParentCategoryId == Guid.Empty))
                    {
                        @RenderCategoryTree(root)
                    }
                </div>
            </div>


            <AddIngredientPopup IsVisible="showIngredientPopup"
                                OnIngredientAdded="HandleNewIngredient"
                                OnClose="() => showIngredientPopup = false" />

            <div class="add-recipe-card ingredients">
                <div class="section-header">
                    <label>Ingredients</label>
                    <button type="button" class="btn-primary" @onclick="TogglePopup">+ Add</button>
                </div>

                <div class="ingredients-list">
                    @foreach (var ing in Ingredients)
                    {
                        <div class="ingredient-row">
                            <input type="number" class="custom-input qty" @bind="ing.Quantity" />
                            <span class="unit">@ing.Unit?.Name</span>
                            <span class="name">@ing.Ingredient?.Name</span>
                            <button type="button" class="btn-delete" @onclick="() => RemoveIngredient(ing)">✕</button>
                        </div>
                    }
                </div>
            </div>

            <div class="add-recipe-card steps">
                <div class="section-header">
                    <label>Cooking process</label>
                    <div class="flex-row">
                        <button type="button" class="btn-primary" @onclick="RemoveStep">- Remove</button>
                        <button type="button" class="btn-primary" @onclick="AddStep">+ Add</button>
                    </div>
                </div>

                <div class="steps-list">
                    @foreach (var step in RecipeSteps)
                    {
                        <div class="step-row">
                            <span class="step-number">@step.StepNumber</span>
                            <textarea class="custom-input" @bind="step.Description" rows="2" placeholder="Describe this step..."></textarea>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (WarningEnabled)
        {
            <div class="warning-box">@WarningText</div>
        }

        <div class="actions">
            <button type="button" class="btn-apply" @onclick="FinishRecipe">
                @(IsEditMode ? "Save changes" : "Create recipe")
            </button>
        </div>
    }
</LoadingView>


@code {
    [Parameter] public Guid? RecipeId { get; set; }
    private bool IsEditMode => RecipeId.HasValue && RecipeId.Value != Guid.Empty;
    private bool isLoading = false;

    private string Title { get; set; } = string.Empty;
    private int Time { get; set; }
    private int Servings { get; set; }
    private Guid SelectedServingUnitId { get; set; }
    private DifficultyLevel Difficulty { get; set; } = DifficultyLevel.Medium;
    private List<DifficultyLevel> DifficultyOptions { get; set; } = Enum.GetValues(typeof(DifficultyLevel)).Cast<DifficultyLevel>().ToList();

    private List<UnitPreviewDto> ServingUnits { get; set; } = new();
    private List<CategorySelectableBlazor> Categories { get; set; } = new();
    private List<RecipeIngredient> Ingredients { get; set; } = new();
    private List<RecipeStep> RecipeSteps { get; set; } = new();

    private bool showIngredientPopup = false;
    private List<IngredientPreview> allIngredients = new();

    private string SelectedImagePreview { get; set; } = string.Empty;
    private IBrowserFile? _selectedPhoto;

    private bool WarningEnabled { get; set; }
    private string WarningText { get; set; } = string.Empty;

    UserDisplayDto? userDto;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        userDto = await UserService.GetCurrentUserAsync();

        if (userDto is null)
        {
            NavManager.NavigateTo("/login");
            return;
        }

        ServingUnits = await UnitService.GetAllServingUnitsAsync();

        var cats = await CategoryService.GetAllCategoriesAsync();
        Categories = cats.Select(c => new CategorySelectableBlazor { Category = c, IsSelected = false }).ToList();

        if (IsEditMode)
        {
            var existingRecipe = await RecipeService.GetRecipeDetailsAsync(RecipeId.Value);

            if (existingRecipe != null)
            {
                Title = existingRecipe.Title;
                Time = existingRecipe.CookingTime;
                Servings = existingRecipe.ServingsAmount;
                SelectedServingUnitId = existingRecipe.ServingUnit.Id;
                Difficulty = (DifficultyLevel)existingRecipe.Difficulty;

                SelectedImagePreview = !string.IsNullOrEmpty(existingRecipe.PhotoUrl) ? existingRecipe.PhotoUrl : string.Empty;
                Ingredients = existingRecipe.RecipeIngredients.Select(ingDto => new RecipeIngredient
                {
                    IngredientId = ingDto.IngredientId,
                    UnitId = ingDto.UnitId,
                    Quantity = ingDto.Quantity,
                    Ingredient = new Ingredient { Name = ingDto.IngredientName },
                    Unit = new Unit { Name = ingDto.UnitName }
                }).ToList();
                RecipeSteps = existingRecipe.RecipeSteps.OrderBy(s => s.StepNumber).ToList();

                var existingCatIds = existingRecipe.Categories.Select(c => c.Id).ToList();
                foreach (var cat in Categories)
                {
                    if (existingCatIds.Contains(cat.Category.Id))
                    {
                        cat.IsSelected = true;
                        ExpandParentRecursive(cat.Category.ParentCategoryId);
                    }
                }
            }
            else
            {
                NavManager.NavigateTo("/recipes");
            }
        }
        else
        {
            if (ServingUnits.Any()) SelectedServingUnitId = ServingUnits.First().Id;
            AddStep();
            AddStep();
        }

        isLoading = false;
    }

    private void ExpandParentRecursive(Guid? parentId)
    {
        if (parentId == null || parentId == Guid.Empty) return;

        var parent = Categories.FirstOrDefault(c => c.Category.Id == parentId);
        if (parent != null)
        {
            parent.IsExpanded = true;
            ExpandParentRecursive(parent.Category.ParentCategoryId);
        }
    }

    private void AddStep()
    {
        RecipeSteps.Add(new RecipeStep { StepNumber = (short)(RecipeSteps.Count + 1), Description = string.Empty });
    }

    private void RemoveStep()
    {
        if (RecipeSteps.Count > 1)
        {
            RecipeSteps.RemoveAt(RecipeSteps.Count - 1);
        }
    }

    private void RemoveIngredient(RecipeIngredient ing)
    {
        Ingredients.Remove(ing);
    }

    private void HandleNewIngredient(RecipeIngredient ingredient)
    {
        Ingredients.Add(ingredient);
        showIngredientPopup = false;
    }

    private void TogglePopup()
    {
        showIngredientPopup = !showIngredientPopup;
    }

    private async Task LoadPhoto(InputFileChangeEventArgs e)
    {

        _selectedPhoto = e.File;


        var buffer = new byte[_selectedPhoto.Size];
        using var stream = _selectedPhoto.OpenReadStream(maxAllowedSize: 5120000);
        await stream.ReadAsync(buffer);

        SelectedImagePreview = $"data:{_selectedPhoto.ContentType};base64,{Convert.ToBase64String(buffer)}";
    }

    private async Task FinishRecipe()
    {
        WarningEnabled = false;

        if (string.IsNullOrWhiteSpace(Title)) { ShowWarning("Title is mandatory"); return; }
        if (Time <= 0) { ShowWarning("Time is mandatory and can't be 0"); return; }
        if (Servings <= 0) { ShowWarning("Number of servings is mandatory and can't be 0"); return; }
        if (!Categories.Any(c => c.IsSelected)) { ShowWarning("Recipe must have at least one category"); return; }
        if (Ingredients.Count == 0) { ShowWarning("Recipe must have at least one ingredient"); return; }

        foreach (var ing in Ingredients)
        {
            if (ing.Quantity == 0) { ShowWarning($"Ingredient can't have zero quantity"); return; }
        }

        for (int i = 0; i < RecipeSteps.Count; i++)
        {
            RecipeSteps[i].StepNumber = (short)(i + 1);
        }

        foreach (var rs in RecipeSteps)
        {
            if (string.IsNullOrEmpty(rs.Description)) { ShowWarning($"Cooking step can't be empty ({rs.StepNumber})"); return; }
        }

        var dto = new RecipeCreateDto
        {
            Title = Title,
            CookingTime = (short)Time,
            ServingsAmount = (short)Servings,
            ServingUnit = SelectedServingUnitId,
            Difficulty = (short)Difficulty,
            CategoriesIds = Categories.Where(c => c.IsSelected).Select(c => c.Category.Id).ToList(),
            RecipeIngredients = Ingredients,
            RecipeSteps = RecipeSteps
        };

        Stream? photoStream = null;
        if (_selectedPhoto is not null)
        {
            photoStream = _selectedPhoto.OpenReadStream(maxAllowedSize: 5120000);
        }

        try
        {
            if (IsEditMode)
            {
                await RecipeService.UpdateRecipeAsync(dto, RecipeId.Value, photoStream, _selectedPhoto?.Name, _selectedPhoto?.ContentType);
            }
            else
            {
                await RecipeService.SaveRecipeAsync(dto, photoStream, _selectedPhoto?.Name, _selectedPhoto?.ContentType);
            }

            await JSRuntime.InvokeVoidAsync("history.back");
        }
        finally
        {
            photoStream?.Dispose();
        }
    }

    private void ShowWarning(string msg)
    {
        WarningText = msg;
        WarningEnabled = true;
    }

    private void GoBack()
    {
        JSRuntime.InvokeVoidAsync("history.back");
    }

    RenderFragment<CategorySelectableBlazor> RenderCategoryTree => category => __builder =>
    {
        var children = GetChildren(category.Category.Id).ToList();
        var hasChildren = children.Any();

        <div class="category-node">
            <div class="category-chip @(category.IsSelected ? "selected" : "") @(category.IsExpanded ? "expanded" : "")"
                 @onclick="() => HandleClick(category)">

                @if (!string.IsNullOrEmpty(category.Category.PictureUrl) && category.Category.PictureUrl != "default_category_picture.png")
                {
                    <img src="@category.Category.PictureUrl" class="chip-img" />
                }
                <span class="chip-name">@category.Category.Name</span>

                @if (hasChildren)
                {
                    <i class="bi @(category.IsExpanded ? "bi-chevron-down" : "bi-chevron-right") ms-1"></i>
                }
            </div>

            @if (hasChildren && category.IsExpanded)
            {
                <div class="children-wrapper animate-slide-down">
                    @foreach (var child in children)
                    {
                        @RenderCategoryTree(child)
                    }
                </div>
            }
        </div>
    };

    private void HandleClick(CategorySelectableBlazor cat)
    {
        cat.IsSelected = !cat.IsSelected;

        bool hasChildren = Categories.Any(c => c.Category.ParentCategoryId == cat.Category.Id);
        if (hasChildren)
        {
            cat.IsExpanded = !cat.IsExpanded;
        }

        if (!cat.IsSelected)
        {
            DeselectChildrenRecursive(cat.Category.Id);
        }
    }

    private void DeselectChildrenRecursive(Guid parentId)
    {
        var children = Categories.Where(c => c.Category.ParentCategoryId == parentId).ToList();
        foreach (var child in children)
        {
            child.IsSelected = false;
            child.IsExpanded = false;
            DeselectChildrenRecursive(child.Category.Id);
        }
    }

    private IEnumerable<CategorySelectableBlazor> GetChildren(Guid parentId)
        => Categories.Where(c => c.Category.ParentCategoryId == parentId);


    public class CategorySelectableBlazor
    {
        public Category Category { get; set; }
        public bool IsSelected { get; set; }
        public bool IsExpanded { get; set; }
    }
}