@page "/add-recipe"
@using Pinula.Shared.Models
@using Pinula.Shared.DTOs
@using Pinula.Shared.Interface
@using Pinula.WASM.Components
@inject IRecipeService RecipeService
@inject ICategoryService CategoryService
@inject IUnitService UnitService
@inject IIngredientService IngredientService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager
    <div class="header">
        <img src="images/icons/back.png" class="back-btn" @onclick="GoBack" />
        <h1>Add Recipe</h1>
    </div>

    <div class="form-grid">
        <div class="add-recipe-card basic-info">
            <div class="input-group">
                <label>Recipe name</label>
                <input type="text" class="custom-input " @bind="Title" placeholder="e.g. Spaghetti Bolognese" />
            </div>

            <div class="image-upload">
                <div class="image-preview">
                    @if (!string.IsNullOrEmpty(SelectedImagePreview))
                    {
                        <img src="@SelectedImagePreview" alt="Recipe preview" />
                    }
                    else
                    {
                        <span>No image selected</span>
                    }
                </div>
            </div>

        <div class="custom-file-upload">
            <label for="file-upload" class="btn-apply">
                Select image
            </label>
            <InputFile id="file-upload" OnChange="LoadPhoto" />
        </div>

            <div class="stats-row">
                <div class="input-group">
                    <label>Time (Minutes)</label>
                    <input type="number" min="1" class="custom-input" @bind="Time" />

                </div>
                
                <div class="input-group">
                    <label>Servings</label>
                    <div class="flex-row">
                        <input type="number" min="1" class="custom-input" @bind="Servings" />
                        <select class="custom-select" @bind="SelectedServingUnitId">
                            @foreach (var unit in ServingUnits)
                            {
                                <option value="@unit.Id">@unit.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="input-group">
                    <label>Difficulty</label>
                    <select class="custom-select" @bind="Difficulty">
                        @foreach (var diff in DifficultyOptions)
                        {
                            <option value="@diff">@diff.ToString()</option>
                        }
                    </select>
                </div>
            </div>
        </div>


        <div class="add-recipe-card input-group">
            <label>Categories</label>
            <div class="chips-container">
                @foreach (var cat in Categories)
                {
                    <button type="button"
                            class="chip @(cat.IsSelected ? "selected" : "")"
                            @onclick="() => ToggleCategory(cat)">
                        @cat.Category.Name
                    </button>
                }
            </div>
        </div>

        <AddIngredientPopup 
            IsVisible="showIngredientPopup" 
            OnIngredientAdded="HandleNewIngredient" 
            OnClose="() => showIngredientPopup = false" />

        <div class="add-recipe-card ingredients">
            <div class="section-header">
                <label>Ingredients</label>
                <button type="button" class="btn-primary" @onclick="TogglePopup">+ Add</button>
            </div>
            
            <div class="ingredients-list">
                @foreach (var ing in Ingredients)
                {
                    <div class="ingredient-row">
                        <input type="number" class="custom-input qty" @bind="ing.Quantity" />
                        <span class="unit">@ing.Unit?.Name</span>
                        <span class="name">@ing.Ingredient?.Name</span>
                        <button type="button" class="btn-delete" @onclick="() => RemoveIngredient(ing)">✕</button>
                    </div>
                }
            </div>
        </div>

        <div class="add-recipe-card steps">
            <div class="section-header">
                <label>Cooking process</label>
                <div class="flex-row">
                    <button type="button" class="btn-primary" @onclick="RemoveStep">- Remove</button>
                    <button type="button" class="btn-primary" @onclick="AddStep">+ Add</button>
                </div>
            </div>

            <div class="steps-list">
                @foreach (var step in RecipeSteps)
                {
                    <div class="step-row">
                        <span class="step-number">@step.StepNumber</span>
                        <textarea class="custom-input" @bind="step.Description" rows="2" placeholder="Describe this step..."></textarea>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (WarningEnabled)
    {
        <div class="warning-box">@WarningText</div>
    }

    <div class="actions">
        <button type="button" class="btn-apply" @onclick="FinishRecipe">Finish recipe</button>
    </div>

@code {
    private string Title { get; set; } = string.Empty;
    private int Time { get; set; }
    private int Servings { get; set; }
    private Guid SelectedServingUnitId { get; set; }
    private DifficultyLevel Difficulty { get; set; } = DifficultyLevel.Medium;
    private List<DifficultyLevel> DifficultyOptions { get; set; } = Enum.GetValues(typeof(DifficultyLevel)).Cast<DifficultyLevel>().ToList();

    private List<UnitPreviewDto> ServingUnits { get; set; } = new();
    private List<CategorySelectableBlazor> Categories { get; set; } = new();
    private List<RecipeIngredient> Ingredients { get; set; } = new();
    private List<RecipeStep> RecipeSteps { get; set; } = new();

    private bool showIngredientPopup = false;
    private List<IngredientPreview> allIngredients = new();

    private string SelectedImagePreview { get; set; } = string.Empty;
    private IBrowserFile? _selectedPhoto;

    private bool WarningEnabled { get; set; }
    private string WarningText { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        ServingUnits = await UnitService.GetAllServingUnitsAsync();
        if (ServingUnits.Any()) SelectedServingUnitId = ServingUnits.First().Id;

        var cats = await CategoryService.GetAllCategoriesAsync();
        Categories = cats.Select(c => new CategorySelectableBlazor { Category = c, IsSelected = false }).ToList();

        AddStep();
        AddStep();
    }

    private void ToggleCategory(CategorySelectableBlazor cat)
    {
        cat.IsSelected = !cat.IsSelected;
    }

    private void AddStep()
    {
        RecipeSteps.Add(new RecipeStep { StepNumber = (short)(RecipeSteps.Count + 1) });
    }

    private void RemoveStep()
    {
        if (RecipeSteps.Count > 1)
        {
            RecipeSteps.RemoveAt(RecipeSteps.Count - 1);
        }
    }

    private void RemoveIngredient(RecipeIngredient ing)
    {
        Ingredients.Remove(ing);
    }

    private void HandleNewIngredient(RecipeIngredient ingredient)
    {
        Ingredients.Add(ingredient);
        showIngredientPopup = false;
    }

    private void TogglePopup()
    {
        showIngredientPopup = !showIngredientPopup;
    }

    private async Task LoadPhoto(InputFileChangeEventArgs e)
    {

        _selectedPhoto = e.File;


        var buffer = new byte[_selectedPhoto.Size];
        using var stream = _selectedPhoto.OpenReadStream(maxAllowedSize: 5120000);
        await stream.ReadAsync(buffer);
    
        SelectedImagePreview = $"data:{_selectedPhoto.ContentType};base64,{Convert.ToBase64String(buffer)}";
    }

    private async Task FinishRecipe()
    {
        WarningEnabled = false;

        if (string.IsNullOrWhiteSpace(Title)) { ShowWarning("Title is mandatory"); return; }
        if (Time <= 0) { ShowWarning("Time is mandatory and can't be 0"); return; }
        if (Servings <= 0) { ShowWarning("Number of servings is mandatory and can't be 0"); return; }
        if (!Categories.Any(c => c.IsSelected)) { ShowWarning("Recipe must have at least one category"); return; }
        if (Ingredients.Count == 0) { ShowWarning("Recipe must have at least one ingredient"); return; }
        
        foreach (var ing in Ingredients)
        {
            if (ing.Quantity == 0) { ShowWarning($"Ingredient can't have zero quantity"); return; }
        }
        foreach (var rs in RecipeSteps)
        {
            if (string.IsNullOrEmpty(rs.Description)) { ShowWarning($"Cooking step can't be empty ({rs.StepNumber})"); return; }
        }

        var dto = new RecipeCreateDto
        {
            Title = Title,
            CookingTime = (short)Time,
            ServingsAmount = (short)Servings,
            ServingUnit = SelectedServingUnitId,
            Difficulty = (short)Difficulty,
            CategoriesIds = Categories.Where(c => c.IsSelected).Select(c => c.Category.Id).ToList(),
            RecipeIngredients = Ingredients,
            RecipeSteps = RecipeSteps
        };

        if (_selectedPhoto is not null)
        {
            using var photoStream = _selectedPhoto.OpenReadStream(maxAllowedSize: 5120000);
        
            await RecipeService.SaveRecipeAsync(dto,photoStream,_selectedPhoto.Name,_selectedPhoto.ContentType);
        }
        else
        {
            await RecipeService.SaveRecipeAsync(dto, null, null, null);
        }
        await JSRuntime.InvokeVoidAsync("history.back");
    }

    private void ShowWarning(string msg)
    {
        WarningText = msg;
        WarningEnabled = true;
    }

    private void GoBack()
    {
        JSRuntime.InvokeVoidAsync("history.back");
    }

    public class CategorySelectableBlazor
    {
        public Category Category { get; set; } = new();
        public bool IsSelected { get; set; }
    }
}