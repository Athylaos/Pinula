@page "/profile"
@using Pinula.Shared.Interface
@using Pinula.Shared.DTOs
@using Pinula.Shared.Models
@using Pinula.WASM.Components
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IUserService userService
@inject IRecipeService recipeService
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<App> Localizer
@inject ILocalStorage LocalStorage

<PageTitle>Pinula - @(userProfile?.Name ?? "My Profile")</PageTitle>

<div class="pf-page-wrapper">
    <LoadingView IsLoading="@isLoading" Text="@Localizer["LoadingProfile"]" IsFullScreen="true">
        
        <div class="pf-main-header">
            <div class="pf-user-meta">
                <div class="pf-avatar-frame">
                    <img src="@(string.IsNullOrEmpty(userProfile?.AvatarUrl) ? "images/default-avatar.png" : userProfile.AvatarUrl)" alt="Avatar" class="pf-display-avatar" />
                </div>
                <div class="pf-user-identity">
                    <h2 class="pf-user-fullname">@userProfile?.Name @userProfile?.Surname</h2>
                    <span class="pf-user-email-sub">@userProfile?.Email</span>
                </div>
            </div>
            
            <div class="pf-header-actions">
                <button class="pf-icon-action-btn pf-logout-accent" @onclick="HandleLogout" title="@Localizer["LogOut"]">
                    @Localizer["LogOut"]
                </button>
                @if(userProfile.Role == "admin")
                {
                    <button class="pf-icon-action-btn pf-logout-accent" @onclick="HandleAdmin" title="Administrace">
                        ADMIN
                    </button>
                }
                <div class="culture-toggle-container">
                    <button class="btn-culture-toggle @(CurrentCulture == "en" ? "active" : "")" @onclick='() => ChangeCulture("en")'>
                        EN
                    </button>
                    <button class="btn-culture-toggle @(CurrentCulture == "cs" ? "active" : "")" @onclick='() => ChangeCulture("cs")'>
                        CZ
                    </button>
                </div>
            </div>
        </div>

        <div class="pf-stats-container-grid">
            <div class="pf-stat-metric-card">
                <div class="pf-metric-icon">
                    <img src="images/icons/spoon_fork.png" class="pf-metric-img" />
                </div>
                <div class="pf-metric-details">
                    <span class="pf-metric-value">@userProfile?.PostedRecipes</span>
                    <span class="pf-metric-label">@Localizer["RecipesPosted"]</span>
                </div>
            </div>

            <div class="pf-stat-metric-card">
                <div class="pf-metric-icon pf-icon-star">
                    <img src="images/icons/favorite_full.png" class="pf-metric-img" />
                </div>
                <div class="pf-metric-details">
                    <span class="pf-metric-value">@(userProfile?.AvgRating.ToString("0.0") ?? "0.0")</span>
                    <span class="pf-metric-label">@Localizer["AvgRating"]</span>
                </div>
            </div>

            <div class="pf-stat-metric-card">
                <div class="pf-metric-icon pf-icon-comment">
                    <img src="images/icons/chat.png" class="pf-metric-img" />
                </div>
                <div class="pf-metric-details">
                    <span class="pf-metric-value">@userProfile?.PostedComments</span>
                    <span class="pf-metric-label">@Localizer["Comments"]</span>
                </div>
            </div>

            <div class="pf-stat-metric-card">
                <div class="pf-metric-icon pf-icon-calendar">
                    <img src="images/icons/calendar.png" class="pf-metric-img" />
                </div>
                <div class="pf-metric-details">
                    <span class="pf-metric-value">@userProfile?.UserCreated.ToString("MMM yyyy")</span>
                    <span class="pf-metric-label">@Localizer["MemberSince"]</span>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="pf-alert-toast pf-animate-slide" style="border-left: 4px solid var(--pine-teal);">
                <div class="d-flex justify-content-between align-items-center">
                    <span>@statusMessage</span>
                    <button class="pf-btn-dismiss" @onclick="() => statusMessage = string.Empty">@Localizer["Dismiss"]</button>
                </div>
            </div>
        }

        <div class="pf-mid-layout-grid">
            
            <div class="pf-content-card">
                <div class="pf-card-header-block">
                    <h4>@Localizer["AccountInformations"]</h4>
                </div>
                
                @if (isEditing)
                {
                    <div class="pf-card-scroll-body pf-animate-slide">
						<EditForm Model="@updateModel" OnValidSubmit="HandleUpdateProfile" class="pf-animate-slide">
							<div class="pf-form-group mb-3">
                                <label class="pf-field-caption">@Localizer["FirstName"]</label>
								<InputText @bind-Value="@updateModel.Name" class="pf-text-field" />
							</div>
							<div class="pf-form-group mb-3">
                                <label class="pf-field-caption">@Localizer["LastName"]</label>
								<InputText @bind-Value="@updateModel.Surname" class="pf-text-field" />
							</div>

							<div class="pf-form-group mb-4">
                                <label class="pf-field-caption">@Localizer["AvatarPhoto"]</label>
								<div class="pf-upload-zone">
									<InputFile OnChange="HandleFileSelected" class="pf-text-field pf-file-picker" accept="image/*" />
									@if (selectedFile != null)
									{
                                        <span class="pf-upload-indicator pf-animate-slide">@Localizer["Ready"]: @selectedFile.Name</span>
									}
								</div>
							</div>

							<div class="pf-form-actions-row">
								<button type="button" class="pf-btn-dismiss" @onclick="ToggleEdit">Cancel</button>
								<button type="submit" class="pf-btn-submit-action" disabled="@isSaving">
                                    @(isSaving ? Localizer["Saving"] : Localizer["SaveChanges"])
								</button>
							</div>
						</EditForm>
                    </div>

                }
                else if(isChangingPswd){
                    <div class="pf-card-scroll-body pf-animate-slide">
                        <EditForm Model="@updateModel" OnValidSubmit="HandleChangePassword" class="pf-animate-slide">
                            <div class="pf-form-group mb-3">
                                <label class="pf-field-caption">@Localizer["OldPassword"]</label>
                                <InputText type="password" @bind-Value="oldPswd" class="pf-text-field" />
                            </div>

                            <div class="pf-form-group mb-3">
                                <label class="pf-field-caption">@Localizer["NewPassword"]</label>
                                <InputText type="password" @bind-Value="newPswd1" class="pf-text-field" />
                            </div>

                            <div class="pf-form-group mb-3">
                                <label class="pf-field-caption">@Localizer["NewPasswordAgain"]</label>
                                <InputText type="password" @bind-Value="newPswd2" class="pf-text-field" />
                            </div>

                            <div class="pf-form-actions-row">
                                <button type="button" class="pf-btn-dismiss" @onclick="ToggleChangePassword">@Localizer["Cancel"]</button>
                                <button type="submit" class="pf-btn-submit-action" disabled="@isSaving">
                                    @(isSaving ? Localizer["Saving"] : Localizer["SaveChanges"])
                                </button>
                            </div>
                        </EditForm>
                    </div>
                }
                else
                {
                    <div class="pf-static-view pf-animate-slide">
                        <div class="pf-info-row">
                            <span class="pf-info-title">@Localizer["FirstName"]</span>
                            <span class="pf-info-data">@userProfile?.Name</span>
                        </div>
                        <div class="pf-info-row">
                            <span class="pf-info-title">@Localizer["LastName"]</span>
                            <span class="pf-info-data">@userProfile?.Surname</span>
                        </div>
                        <div class="pf-info-row">
                            <span class="pf-info-title">Email</span>
                            <span class="pf-info-data">@userProfile?.Email</span>
                        </div>
                        
                        <div class="pf-form-actions-row mt-4">
                            <button type="button" class="pf-btn-submit-action" @onclick="ToggleEdit">
                                <i class="bi bi-pencil-fill me-1"></i>@Localizer["EditProfile"]
                            </button>
                            <button type="button" class="pf-btn-submit-action" @onclick="ToggleChangePassword">
                                <i class="bi bi-key-fill"></i> @Localizer["ChangePassword"]
                            </button>
                        </div>
                    </div>
                }
            </div>

            <div class="pf-content-card">
                <div class="pf-card-header-block">
                    <h4>@Localizer["Dashboard"]</h4>
                </div>

                <div class="pf-card-scroll-body">
                    @if (userProfile.CanComment && userProfile.CanCreateRecipes)
                    {
                        <div class="pf-invites-empty-state">
                            <h5>@Localizer["NoNews"]</h5>
                            <p class="pf-field-caption text-center">@Localizer["NoNewsSubtitle"]</p>
                        </div>
                    }
                    else
                    {
                        if (!userProfile.CanComment)
                        {
                            <div class="pf-ban-alert">
                                <div class="prompt-content">
                                    <h5>@Localizer["YouAreBannedComments"]</h5>
                                    <p>@Localizer["YouAreBannedCommentsDescription"]</p>
                                </div>
                            </div>
                        }
                        if (!userProfile.CanCreateRecipes)
                        {
                            <div class="pf-ban-alert">
                                <div class="prompt-content">
                                    <h5>@Localizer["YouAreBannedRecipes"]</h5>
                                    <p>@Localizer["YouAreBannedRecipesDescription"]</p>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

        </div>

        <div class="pf-bottom-fullwidth-section">
            <h3 class="pf-section-heading">@Localizer["MyFavorites"]</h3>
            
            @if (fvRecipes != null && fvRecipes.Any())
            {
                <RecipeGridVertical HasMoreToLoad="@moreFvRecipesToLoad" 
                                   IsLoading="@isFvRecipesLoading" 
                                   OnLoadMore="LoadMoreFvRecipes" 
                                   OnRecipeSelected="RecipeClicked" 
                                   Recipes="fvRecipes">
                </RecipeGridVertical>
            }
            else
            {
                <div class="pf-empty-recipes-fallback">
                    <p>@Localizer["MyFavoritesEmpty"]</p>
                </div>
            }
        </div>
        <div class="pf-bottom-fullwidth-section">
            <h3 class="pf-section-heading">@Localizer["MyRecipes"]</h3>

            @if (myRecipes != null && myRecipes.Any())
            {
                <RecipeGridVertical HasMoreToLoad="@moreRecipesToLoad"
                                    IsLoading="@isRecipesLoading"
                                    OnLoadMore="LoadMoreMyRecipes"
                                    OnRecipeSelected="RecipeClicked"
                                    Recipes="myRecipes"
                                    EnableEdit="true"
                                    OnRecipeEditSelected="RecipeEditClicked">
                </RecipeGridVertical>
            }
            else
            {
                <div class="pf-empty-recipes-fallback">
                    <p>@Localizer["MyRecipesEmpty"]</p>
                </div>
            }
        </div>

    </LoadingView>
</div>

@code {
    private UserDisplayDto? userProfile;
    private UserUpdateDto updateModel = new();
    private string oldPswd;
    private string newPswd1;
    private string newPswd2;

    private List<RecipePreviewDto> myRecipes = new();
    private List<RecipePreviewDto> fvRecipes = new();

    private bool isLoading = true;
    private bool isRecipesLoading = false;
    private bool moreRecipesToLoad = true;
    private bool isSaving = false;
    private bool isEditing = false;
    private bool isChangingPswd = false;

    private bool isFvRecipesLoading = false;
    private bool moreFvRecipesToLoad = true;

    private string statusMessage = string.Empty;
    private readonly RecipeFilterParameters _mineFilter = new() { OnlyMine = true, Amount = 6 };
    private readonly RecipeFilterParameters _fvFilter = new() { OnlyFavorites = true, Amount = 6 };

    private IBrowserFile? selectedFile;
    private long maxFileSize = 1024 * 1024 * 5;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileData();
    }

    private async Task LoadProfileData()
    {
        isLoading = true;
        try
        {
            userProfile = await userService.GetCurrentUserAsync();

            if (userProfile == null)
            {
                NavManager.NavigateTo("/login");
                return;
            }

            updateModel.Name = userProfile.Name;
            updateModel.Surname = userProfile.Surname;

            var recipesResult = await recipeService.GetFilteredRecipePreviewsAsync(_mineFilter, null);
            myRecipes = recipesResult?.ToList() ?? new();

            if (myRecipes.Count < _mineFilter.Amount)
            {
                moreRecipesToLoad = false;
            }

            var fvRecipesResult = await recipeService.GetFilteredRecipePreviewsAsync(_fvFilter, null);
            fvRecipes = fvRecipesResult?.ToList() ?? new();

            if (fvRecipes.Count < _mineFilter.Amount)
            {
                moreFvRecipesToLoad = false;
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadMoreMyRecipes()
    {
        isRecipesLoading = true;
        _mineFilter.Skip = myRecipes.Count;

        var results = await recipeService.GetFilteredRecipePreviewsAsync(_mineFilter, null);
        var newList = results?.ToList() ?? new List<RecipePreviewDto>();

        if (!newList.Any() || newList.Count < _mineFilter.Amount)
        {
            moreRecipesToLoad = false;
        }

        myRecipes.AddRange(newList);
        isRecipesLoading = false;
    }

    private async Task LoadMoreFvRecipes()
    {
        isFvRecipesLoading = true;
        _fvFilter.Skip = fvRecipes.Count;

        var results = await recipeService.GetFilteredRecipePreviewsAsync(_fvFilter, null);
        var newList = results?.ToList() ?? new List<RecipePreviewDto>();

        if (!newList.Any() || newList.Count < _fvFilter.Amount)
        {
            moreFvRecipesToLoad = false;
        }

        fvRecipes.AddRange(newList);
        isFvRecipesLoading = false;
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private void ToggleEdit()
    {
        isEditing = !isEditing;
        if (!isEditing && userProfile != null)
        {
            updateModel.Name = userProfile.Name;
            updateModel.Surname = userProfile.Surname;
            selectedFile = null;
        }
    }

    private void ToggleChangePassword()
    {
        isChangingPswd= !isChangingPswd;
        if (!isChangingPswd && userProfile != null)
        {
            oldPswd = string.Empty;
            newPswd1 = string.Empty;
            newPswd2 = string.Empty;
        }
    }

    private async Task HandleChangePassword()
    {
        isSaving = true;
        statusMessage = string.Empty;

        if(newPswd1 != newPswd2)
        {
            statusMessage = Localizer["PasswordsNotMatching"];
            isChangingPswd = false;
            isSaving = false;
            return;
        }

        if (newPswd1.Length < 5)
        {
            statusMessage = Localizer["ToShortPassword"];
            isChangingPswd = false;
            isSaving = false;
            return;
        }

        try
        {
            var status = await userService.ChangePasswordAsync(oldPswd, newPswd1);

            if (status)
            {
                statusMessage = @Localizer["PasswordUpdateSucess"];
            }
            else
            {
                statusMessage = Localizer["WrongPassword"];
            }
        }
        catch (Exception ex)
        {
            statusMessage = Localizer["ChangingPasswordError"];
        }
        finally
        {
            isChangingPswd = false;
            isSaving = false;
        }
    }

    private async Task HandleUpdateProfile()
    {
        isSaving = true;
        statusMessage = string.Empty;
        Stream? stream = null;

        try
        {
            if (selectedFile != null)
            {
                stream = selectedFile.OpenReadStream(maxFileSize);
            }

            var success = await userService.UpdateUserAsync(
                updateModel, 
                stream, 
                selectedFile?.Name ?? string.Empty, 
                selectedFile?.ContentType ?? string.Empty
            );

            if (success)
            {
                statusMessage = Localizer["ProfileUpdatedSucess"];
                isEditing = false;
                selectedFile = null;
                await LoadProfileData();
            }
            else
            {
                statusMessage = Localizer["ProfileUpdateFail"];
            }
        }
        catch (Exception ex)
        {
            statusMessage = Localizer["ProfileUpdateProcessFail"];
        }
        finally
        {
            if (stream != null) await stream.DisposeAsync();
            isSaving = false;
            isEditing = false;
        }
    }

    private void HandleLogout()
    {
        userService.Logout();
        NavManager.NavigateTo("/recipes", forceLoad: true);
    }

    private string CurrentCulture => CultureInfo.CurrentCulture.Name;

    private async Task ChangeCulture(string cultureCode)
    {
        if (CurrentCulture == cultureCode) return;
        await LocalStorage.SetStringAsync("culture", cultureCode);

       NavManager.NavigateTo(NavManager.Uri, forceLoad: true);
    }

    private void HandleAdmin() => NavManager.NavigateTo("/admin");
    private void RecipeClicked(RecipePreviewDto r) => NavManager.NavigateTo($"/recipe/{r.Id}");
    private void RecipeEditClicked(RecipePreviewDto r) => NavManager.NavigateTo($"/recipe/edit/{r.Id}");

}