@page "/login"
@using Pinula.Shared.DTOs
@using Pinula.Shared.Interface
@using Pinula.WASM.Services
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IUserService UserService
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject ApiAuthenticationStateProvider AuthStateProvider
@inject ILocalStorage LocalStorage
@inject IStringLocalizer<App> Localizer

<PageTitle>@Localizer["LoginPage"]</PageTitle>

<div class="login-page">
    <div class="culture-toggle-container position-absolute login-language-container">
        <button class="btn-culture-toggle @(CurrentCulture == "en" ? "active" : "")" @onclick='() => ChangeCulture("en")'>
            EN
        </button>
        <button class="btn-culture-toggle @(CurrentCulture == "cs" ? "active" : "")" @onclick='() => ChangeCulture("cs")'>
            CZ
        </button>
    </div>
    <div class="login-container">
        <div class="header-section">
            <h1 class="login-title">@Localizer["Login"]</h1>
            <p class="login-subtitle">@Localizer["WelcomeBack"]</p>
        </div>

        <div class="form-section">
            <div class="input-group">
                <input type="email"
                       placeholder="Email"
                       @bind="email"
                       class="custom-input" />
            </div>

            <div class="input-group">
                <input type="password"
                       placeholder="@Localizer["Password"]"
                       @bind="password"
                       class="custom-input" />
            </div>

            @if (indicatorVisibility)
            {
                <div class="error-message">
                    @indicatorText
                </div>
            }

            <button class="btn-continue" @onclick="LoginBtn" disabled="@isBusy">
                @if (isBusy)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <span>@Localizer["Continue"]</span>
                }
            </button>
        </div>

        <div class="footer-section">
            <button class="btn-link" @onclick="CreateAccountBtn">@Localizer["CreateAccount"]</button>
            <button class="btn-link" @onclick="ForgotPasswordBtn">@Localizer["ForgotPassword"]</button>
        </div>

        <button class="btn-skip" @onclick="SkipBtn">@Localizer["Skip"]</button>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private bool indicatorVisibility = false;
    private string indicatorText = string.Empty;
    private bool isBusy = false;

    private async Task LoginBtn()
    {
        isBusy = true;
        indicatorVisibility = false;

        try
        {
            var loginDto = new UserLoginDto { Email = email, Password = password };
            var result = await UserService.LoginAsync(loginDto);

            if (result == null)
            {
                indicatorText = Localizer["WrongLogin"];
                indicatorVisibility = true;
            }
            else
            {
                var customAuthStateProvider = (ApiAuthenticationStateProvider)AuthStateProvider;
                customAuthStateProvider.MarkUserAsAuthenticated(await LocalStorage.GetTokenAsync());
                try
                {
                    await JSRuntime.InvokeVoidAsync("history.back");
                }
                catch
                {
                    NavManager.NavigateTo("/");
                }
            }
        }
        catch (Exception ex)
        {
            indicatorText = Localizer["LoginError"];
            indicatorVisibility = true;
        }
        finally
        {
            isBusy = false;
        }
    }

    private string CurrentCulture => CultureInfo.CurrentCulture.Name;

    private async Task ChangeCulture(string cultureCode)
    {
        if (CurrentCulture == cultureCode) return;
        await LocalStorage.SetStringAsync("culture", cultureCode);

        NavManager.NavigateTo(NavManager.Uri, forceLoad: true);
    }

    private void CreateAccountBtn() => NavManager.NavigateTo("/register");

    private void ForgotPasswordBtn()
    {
        indicatorText = Localizer["PasswordResetMsg"];
        indicatorVisibility = true;
    }

    private void SkipBtn() => JSRuntime.InvokeVoidAsync("history.back");
}