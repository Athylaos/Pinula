@page "/register"
@using Pinula.Shared.DTOs
@using Pinula.Shared.Interface
@using System.Net.Mail
@using Microsoft.Extensions.Localization
@inject IUserService UserService
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<App> Localizer

<PageTitle>Pinula - </PageTitle>

<div class="login-page">
    <div class="login-container">
        
        <div class="header-section">
            <h1 class="login-title">@Localizer["Register"]</h1>
            <p class="login-subtitle">@Localizer["JoinUs"]</p>
        </div>

        <div class="form-section">
            <div class="input-group">
                <input type="text" placeholder="@Localizer["FirstName"]" @bind="nameEntry" class="custom-input" />
            </div>

            <div class="input-group">
                <input type="text" placeholder="@Localizer["LastName"]" @bind="surnameEntry" class="custom-input" />
            </div>

            <div class="input-group">
                <input type="email" placeholder="Email" @bind="emailEntry" class="custom-input" />
            </div>

            <div class="input-group">
                <input type="password" placeholder="@Localizer["Password"]" @bind="password1" class="custom-input" />
            </div>

            <div class="input-group">
                <input type="password" placeholder="@Localizer["PasswordAgain"]" @bind="password2" class="custom-input" />
            </div>

            @if (indicatorVisibility)
            {
                <div class="error-message">
                    @indicatorText
                </div>
            }

            <button class="btn-continue" @onclick="RegisterBtn" disabled="@isBusy">
                @if (isBusy)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <span>Continue</span>
                }
            </button>
        </div>

        <div class="footer-section">
            <button class="btn-link" @onclick="LoginBtn">@Localizer["LoginToExisting"]</button>
        </div>

        <div class="bottom-controls">
            <button class="btn-skip" @onclick="BackBtn">@Localizer["Back"]</button>
            <button class="btn-skip" @onclick="SkipBtn">@Localizer["Skip"]</button>
        </div>
    </div>
</div>

@code {
    private string nameEntry = "";
    private string surnameEntry = "";
    private string emailEntry = "";
    private string password1 = "";
    private string password2 = "";

    private bool indicatorVisibility = false;
    private string indicatorText = "";
    private bool isBusy = false;

    private async Task RegisterBtn()
    {
        if (string.IsNullOrWhiteSpace(nameEntry) || string.IsNullOrWhiteSpace(surnameEntry) || string.IsNullOrWhiteSpace(emailEntry))
        {
            ShowError(Localizer["FillAllFields"]);
            return;
        }

        if (!IsValidEmail(emailEntry))
        {
            ShowError(Localizer["InvalidEmailForamt"]);
            return;
        }

        if (password1 != password2)
        {
            ShowError(Localizer["PasswordsNotMatching"]);
            return;
        }

        if (password1.Length < 6)
        {
            ShowError(Localizer["ToShortPassword"]);
            return;
        }


        isBusy = true;
        indicatorVisibility = false;

        try
        {
            var registrationDto = new UserRegistrationDto
            {
                Name = nameEntry,
                Surname = surnameEntry,
                Email = emailEntry,
                Password = password1
            };

            var success = await UserService.RegisterAsync(registrationDto);
            if (!success)
            {
                ShowError(Localizer["EmailAlreadyRegistred"]);
                return;
            }

            var loginResult = await UserService.LoginAsync(new UserLoginDto { Email = emailEntry, Password = password1 });
            if (loginResult != null)
            {
                try
                {
                    await JSRuntime.InvokeVoidAsync("history.go", -2);
                }
                catch
                {
                    NavManager.NavigateTo("/");
                }
            }
        }
        catch (Exception)
        {
            ShowError(Localizer["RegistrationError"]);
        }
        finally
        {
            isBusy = false;
        }
    }

    private void ShowError(string text)
    {
        indicatorText = text;
        indicatorVisibility = true;
    }

    private bool IsValidEmail(string email)
    {
        try
        {
            var addr = new MailAddress(email);
            return addr.Address == email;
        }
        catch { return false; }
    }

    private void LoginBtn() => NavManager.NavigateTo("/login");

    private async Task BackBtn() => await JSRuntime.InvokeVoidAsync("history.go", -2);

    private void SkipBtn() => NavManager.NavigateTo("/");
}